{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "可信拼车",
  "version": "0.0.2",
  "identifier": "ai.cnaigc.trusted-carpool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "可信拼车",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://p2p.cnaigc.ai wss://p2p.cnaigc.ai"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "trusted-carpool"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "一键发车与上车",
    "longDescription": "让 Claude Code 与 Codex 本机账号安全地支持最多四人可信拼车。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "compression": "zlib"
      }
    }
  }
}
