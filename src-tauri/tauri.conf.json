{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "可信拼车",
  "version": "0.0.8",
  "identifier": "ai.cnaigc.trusted-carpool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "可信拼车",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "backgroundColor": "#0f1115"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://p2p.cnaigc.ai wss://p2p.cnaigc.ai"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "trusted-carpool"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBNEU5RkQ1RjI1QTAxQkUKUldTK0FWcnkxWjlPR3NyZndPMTZFeVZOL2Z0ZEdQdThOaHFVcXRjVGtsZVpDY1l3dU1vZTdCbjAK",
      "endpoints": [
        "https://github.com/sunjackson/ai-trusted-carpool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "一键发车与上车",
    "longDescription": "让 Claude Code 与 Codex 本机账号安全地支持最多四人可信拼车。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "compression": "zlib"
      }
    }
  }
}
